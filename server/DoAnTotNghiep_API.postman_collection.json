{
	"info": {
		"_postman_id": "a1b2c3d4-e5f6-7890-abcd-ef1234567890",
		"name": "DoAnTotNghiep API - CONDENSED TEST SUITE ✅",
		"description": "**ESSENTIAL TEST CASES ONLY** - Streamlined Postman collection\n\n**Quick Start Flow:**\n1. Health Check → 2. Login → 3. Create Campaign → 4. Create Draft → 5. Approve Draft (blockchain mint) → 6. Test Webhooks\n\n**Variables needed:**\n- baseUrl: http://localhost:3000\n- authToken: Set auto by login endpoint\n- campaignId: Set auto by create campaign\n- draftCampaignId: Set auto by create draft\n\n**Test Sections:** Health | Auth | Campaigns | Webhooks | Draft Mode | Blockchain",
		"schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
	},
	"variable": [
		{ "key": "baseUrl",    "value": "http://localhost:3000", "type": "string" },
		{ "key": "campaignId", "value": "REPLACE_WITH_REAL_UUID", "type": "string" },
		{ "key": "draftCampaignId", "value": "REPLACE_WITH_DRAFT_UUID", "type": "string" },
		{ "key": "authToken",  "value": "",                      "type": "string" }
	],
	"item": [

		{
			"name": "1. Health Check",
			"item": [
				{
					"name": "GET / - Server Running",
					"event": [{ "listen": "test", "script": { "exec": [
						"pm.test('Status 200', () => pm.response.to.have.status(200));",
						"pm.test('Has message', () => pm.expect(pm.response.json()).to.have.property('message'));"
					], "type": "text/javascript" }}],
					"request": {
						"method": "GET", "header": [],
						"url": { "raw": "{{baseUrl}}/", "host": ["{{baseUrl}}"], "path": [""] }
					}
				},
				{
					"name": "GET /api/health",
					"event": [{ "listen": "test", "script": { "exec": [
						"pm.test('Status 200', () => pm.response.to.have.status(200));",
						"pm.test('Status = OK', () => pm.expect(pm.response.json().status).to.eql('OK'));"
					], "type": "text/javascript" }}],
					"request": {
						"method": "GET", "header": [],
						"url": { "raw": "{{baseUrl}}/api/health", "host": ["{{baseUrl}}"], "path": ["api","health"] }
					}
				}
			]
		},

		{
			"name": "2. Auth",
			"item": [
				{
					"name": "POST /api/auth/login - Get token",
					"event": [{ "listen": "test", "script": { "exec": [
						"pm.test('Status 200', () => pm.response.to.have.status(200));",
						"const json = pm.response.json();",
						"if (json.token) {",
						"  pm.collectionVariables.set('authToken', json.token);",
						"  pm.test('Token saved', () => pm.expect(json.token).to.be.a('string'));",
						"}"
					], "type": "text/javascript" }}],
					"request": {
						"method": "POST",
						"header": [{ "key": "Content-Type", "value": "application/json" }],
						"body": { "mode": "raw", "raw": "{\n  \"email\": \"REPLACE_ADMIN_EMAIL\",\n  \"password\": \"REPLACE_ADMIN_PASSWORD\"\n}" },
						"url": { "raw": "{{baseUrl}}/api/auth/login", "host": ["{{baseUrl}}"], "path": ["api","auth","login"] }
					}
				},
				{
					"name": "POST /api/auth/register - New user",
					"event": [{ "listen": "test", "script": { "exec": [
						"pm.test('Status 200 or 400', () => pm.expect([200,400]).to.include(pm.response.code));"
					], "type": "text/javascript" }}],
					"request": {
						"method": "POST",
						"header": [{ "key": "Content-Type", "value": "application/json" }],
						"body": { "mode": "raw", "raw": "{\n  \"email\": \"newuser_{{$randomInt}}@example.com\",\n  \"password\": \"Test@1234\"\n}" },
						"url": { "raw": "{{baseUrl}}/api/auth/register", "host": ["{{baseUrl}}"], "path": ["api","auth","register"] }
					}
				},
				{
					"name": "POST /api/auth/logout",
					"event": [{ "listen": "test", "script": { "exec": [
						"pm.test('Status 200', () => pm.response.to.have.status(200));"
					], "type": "text/javascript" }}],
					"request": {
						"method": "POST",
						"header": [{ "key": "Content-Type", "value": "application/json" }],
						"body": { "mode": "raw", "raw": "{}" },
						"url": { "raw": "{{baseUrl}}/api/auth/logout", "host": ["{{baseUrl}}"], "path": ["api","auth","logout"] }
					}
				}
			]
		},

		{
			"name": "3. Campaigns CRUD",
			"item": [
				{
					"name": "POST /api/campaigns - Create",
					"event": [{ "listen": "test", "script": { "exec": [
						"pm.test('Status 200-201', () => pm.expect([200,201]).to.include(pm.response.code));",
						"const json = pm.response.json();",
						"if (json && json.id) {",
						"  pm.collectionVariables.set('campaignId', json.id);",
						"} else if (Array.isArray(json) && json[0] && json[0].id) {",
						"  pm.collectionVariables.set('campaignId', json[0].id);",
						"}"
					], "type": "text/javascript" }}],
					"request": {
						"method": "POST",
						"header": [
							{ "key": "Content-Type", "value": "application/json" },
							{ "key": "Authorization", "value": "Bearer {{authToken}}" }
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"title\": \"Campaign 2026\",\n  \"description\": \"Help those in need\",\n  \"goal_amount\": 50000000,\n  \"category_id\": 3,\n  \"start_date\": \"2026-04-01T00:00:00Z\",\n  \"end_date\": \"2026-06-30T00:00:00Z\",\n  \"status\": \"draft\"\n}"
						},
						"url": { "raw": "{{baseUrl}}/api/campaigns", "host": ["{{baseUrl}}"], "path": ["api","campaigns"] }
					}
				},
				{
					"name": "GET /api/campaigns - List all",
					"event": [{ "listen": "test", "script": { "exec": [
						"pm.test('Status 200', () => pm.response.to.have.status(200));",
						"pm.test('Array response', () => pm.expect(pm.response.json()).to.be.an('array'));"
					], "type": "text/javascript" }}],
					"request": {
						"method": "GET", "header": [],
						"url": { "raw": "{{baseUrl}}/api/campaigns", "host": ["{{baseUrl}}"], "path": ["api","campaigns"] }
					}
				},
				{
					"name": "GET /api/campaigns/:id",
					"event": [{ "listen": "test", "script": { "exec": [
						"pm.test('Status 200 or 404', () => pm.expect([200,404]).to.include(pm.response.code));"
					], "type": "text/javascript" }}],
					"request": {
						"method": "GET", "header": [],
						"url": { "raw": "{{baseUrl}}/api/campaigns/{{campaignId}}", "host": ["{{baseUrl}}"], "path": ["api","campaigns","{{campaignId}}"] }
					}
				},
				{
					"name": "PUT /api/campaigns/:id - Update",
					"event": [{ "listen": "test", "script": { "exec": [
						"pm.test('Status 200', () => pm.response.to.have.status(200));"
					], "type": "text/javascript" }}],
					"request": {
						"method": "PUT",
						"header": [
							{ "key": "Content-Type", "value": "application/json" },
							{ "key": "Authorization", "value": "Bearer {{authToken}}" }
						],
						"body": { "mode": "raw", "raw": "{\n  \"title\": \"Updated Campaign\",\n  \"goal_amount\": 100000000\n}" },
						"url": { "raw": "{{baseUrl}}/api/campaigns/{{campaignId}}", "host": ["{{baseUrl}}"], "path": ["api","campaigns","{{campaignId}}"] }
					}
				},
				{
					"name": "DELETE /api/campaigns/:id",
					"event": [{ "listen": "test", "script": { "exec": [
						"pm.test('Status 200 or 204', () => pm.expect([200,204]).to.include(pm.response.code));"
					], "type": "text/javascript" }}],
					"request": {
						"method": "DELETE",
						"header": [{ "key": "Authorization", "value": "Bearer {{authToken}}" }],
						"url": { "raw": "{{baseUrl}}/api/campaigns/{{campaignId}}", "host": ["{{baseUrl}}"], "path": ["api","campaigns","{{campaignId}}"] }
					}
				}
			]
		},

		{
			"name": "4. Webhooks",
			"item": [
