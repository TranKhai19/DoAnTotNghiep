						"if (arr.length > 0) {",
						"  const first = arr[0];",
						"  pm.test('Có field id', () => pm.expect(first).to.have.property('id'));",
						"  pm.test('Có field title', () => pm.expect(first).to.have.property('title'));",
						"  pm.test('Có field goal_amount', () => pm.expect(first).to.have.property('goal_amount'));",
						"  pm.test('Có field raised_amount', () => pm.expect(first).to.have.property('raised_amount'));",
						"  pm.test('Có field category_id', () => pm.expect(first).to.have.property('category_id'));",
						"  pm.test('Có field status', () => pm.expect(first).to.have.property('status'));",
						"  pm.test('Có field start_date', () => pm.expect(first).to.have.property('start_date'));",
						"  pm.test('Có field end_date', () => pm.expect(first).to.have.property('end_date'));",
