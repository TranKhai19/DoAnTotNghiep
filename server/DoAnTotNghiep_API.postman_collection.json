				{
					"name": "POST /api/webhooks/ethereum - Valid",
					"event": [{ "listen": "test", "script": { "exec": [
						"pm.test('Status 200-202', () => pm.expect([200,202,404]).to.include(pm.response.code));"
					], "type": "text/javascript" }}],
					"request": {
						"method": "POST",
						"header": [{ "key": "Content-Type", "value": "application/json" }],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"transactionHash\": \"0xabcdef{{$randomInt}}\",\n  \"amount\": 250000,\n  \"campaignId\": \"{{campaignId}}\",\n  \"contractAddress\": \"0x1234567890abcdef1234567890abcdef12345678\",\n  \"blockNumber\": 18500000\n}"
						},
						"url": { "raw": "{{baseUrl}}/api/webhooks/ethereum", "host": ["{{baseUrl}}"], "path": ["api","webhooks","ethereum"] }
