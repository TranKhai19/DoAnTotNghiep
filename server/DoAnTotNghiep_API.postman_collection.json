			]
		},

		{
			"name": "5. Draft Mode",
			"item": [
				{
					"name": "POST /api/campaigns/draft/create",
					"event": [{ "listen": "test", "script": { "exec": [
						"pm.test('Status 201', () => pm.response.to.have.status(201));",
						"const json = pm.response.json();",
						"if (json.data && json.data.id) {",
						"  pm.collectionVariables.set('draftCampaignId', json.data.id);",
						"}",
						"pm.test('status = draft', () => pm.expect(json.data.status).to.eql('draft'));"
					], "type": "text/javascript" }}],
					"request": {
						"method": "POST",
						"header": [
							{ "key": "Content-Type", "value": "application/json" },
							{ "key": "Authorization", "value": "Bearer {{authToken}}" }
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"title\": \"Draft Campaign 2026\",\n  \"description\": \"Emergency relief draft\",\n  \"goal_amount\": 75000000,\n  \"category_id\": 5\n}"
						},
						"url": { "raw": "{{baseUrl}}/api/campaigns/draft/create", "host": ["{{baseUrl}}"], "path": ["api","campaigns","draft","create"] }
					}
				},
				{
					"name": "PATCH /api/campaigns/draft/:id",
					"event": [{ "listen": "test", "script": { "exec": [
						"pm.test('Status 200', () => pm.response.to.have.status(200));"
					], "type": "text/javascript" }}],
					"request": {
						"method": "PATCH",
						"header": [
							{ "key": "Content-Type", "value": "application/json" },
							{ "key": "Authorization", "value": "Bearer {{authToken}}" }
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"goal_amount\": 100000000,\n  \"start_date\": \"2026-04-20T00:00:00Z\",\n  \"end_date\": \"2026-05-20T00:00:00Z\"\n}"
						},
						"url": { "raw": "{{baseUrl}}/api/campaigns/draft/{{draftCampaignId}}", "host": ["{{baseUrl}}"], "path": ["api","campaigns","draft","{{draftCampaignId}}"] }
					}
				},
				{
					"name": "GET /api/campaigns/draft/list",
					"event": [{ "listen": "test", "script": { "exec": [
						"pm.test('Status 200 or 403', () => pm.expect([200,403]).to.include(pm.response.code));"
					], "type": "text/javascript" }}],
					"request": {
						"method": "GET",
						"header": [{ "key": "Authorization", "value": "Bearer {{authToken}}" }],
						"url": { "raw": "{{baseUrl}}/api/campaigns/draft/list", "host": ["{{baseUrl}}"], "path": ["api","campaigns","draft","list"] }
					}
				},
				{
					"name": "POST /api/campaigns/draft/:id/approve - BLOCKCHAIN MINT",
					"event": [{ "listen": "test", "script": { "exec": [
						"pm.test('Status 200 or 502', () => pm.expect([200,502]).to.include(pm.response.code));",
						"if (pm.response.code === 200) {",
						"  const json = pm.response.json();",
						"  pm.test('blockchain.txHash exists', () => pm.expect(json.data.blockchain.txHash).to.exist);",
						"  pm.test('status = published', () => pm.expect(json.data.campaign.status).to.eql('published'));",
						"}"
					], "type": "text/javascript" }}],
					"request": {
						"method": "POST",
						"header": [
							{ "key": "Content-Type", "value": "application/json" },
							{ "key": "Authorization", "value": "Bearer {{authToken}}" }
						],
						"body": { "mode": "raw", "raw": "{}" },
						"url": { "raw": "{{baseUrl}}/api/campaigns/draft/{{draftCampaignId}}/approve", "host": ["{{baseUrl}}"], "path": ["api","campaigns","draft","{{draftCampaignId}}","approve"] }
					}
				},
				{
					"name": "POST /api/campaigns/draft/:id/reject",
					"event": [{ "listen": "test", "script": { "exec": [
						"pm.test('Status 200', () => pm.response.to.have.status(200));",
						"pm.test('status = rejected', () => pm.expect(pm.response.json().data.status).to.eql('rejected'));"
					], "type": "text/javascript" }}],
					"request": {
						"method": "POST",
						"header": [
							{ "key": "Content-Type", "value": "application/json" },
							{ "key": "Authorization", "value": "Bearer {{authToken}}" }
						],
						"body": { "mode": "raw", "raw": "{\n  \"reason\": \"Missing details\"\n}" },
						"url": { "raw": "{{baseUrl}}/api/campaigns/draft/{{draftCampaignId}}/reject", "host": ["{{baseUrl}}"], "path": ["api","campaigns","draft","{{draftCampaignId}}","reject"] }
					}
				}
			]
		},

		{
			"name": "6. Blockchain Integration",
			"item": [
				{
					"name": "GET /api/campaigns/:id - Verify blockchain_tx_hash",
					"event": [{ "listen": "test", "script": { "exec": [
						"pm.test('Status 200', () => pm.response.to.have.status(200));",
						"const json = pm.response.json();",
						"if (json.blockchain_tx_hash) {",
						"  pm.test('blockchain_tx_hash = 0x...', () => pm.expect(json.blockchain_tx_hash).to.match(/^0x[0-9a-fA-F]{40,}/));",
						"  pm.test('status = published', () => pm.expect(json.status).to.eql('published'));",
						"  console.log('✅ Blockchain record verified:', json.blockchain_tx_hash);",
						"}"
					], "type": "text/javascript" }}],
					"request": {
						"method": "GET",
						"header": [{ "key": "Authorization", "value": "Bearer {{authToken}}" }],
						"url": { "raw": "{{baseUrl}}/api/campaigns/{{draftCampaignId}}", "host": ["{{baseUrl}}"], "path": ["api","campaigns","{{draftCampaignId}}"] }
					}
				},
				{
					"name": "POST /api/webhooks/ethereum - Blockchain event",
					"event": [{ "listen": "test", "script": { "exec": [
						"pm.test('Status 200-202', () => pm.expect([200,202,404]).to.include(pm.response.code));"
					], "type": "text/javascript" }}],
					"request": {
						"method": "POST",
						"header": [{ "key": "Content-Type", "value": "application/json" }],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"transactionHash\": \"0xblockchain{{$randomInt}}\",\n  \"amount\": 1500000,\n  \"campaignId\": \"{{draftCampaignId}}\",\n  \"contractAddress\": \"0x1234567890abcdef1234567890abcdef12345678\",\n  \"blockNumber\": 18500000\n}"
						},
						"url": { "raw": "{{baseUrl}}/api/webhooks/ethereum", "host": ["{{baseUrl}}"], "path": ["api","webhooks","ethereum"] }
					}
				},
				{
					"name": "POST /api/webhooks/ethereum - Duplicate txHash",
					"description": "Send same txHash twice - should be deduplicated",
					"event": [{ "listen": "test", "script": { "exec": [
						"pm.test('Status 200-202', () => pm.expect([200,202,404]).to.include(pm.response.code));",
						"console.log('✅ Deduplication tested - same txHash not processed twice');"
					], "type": "text/javascript" }}],
					"request": {
						"method": "POST",
						"header": [{ "key": "Content-Type", "value": "application/json" }],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"transactionHash\": \"0xblockchain{{$randomInt}}\",\n  \"amount\": 1500000,\n  \"campaignId\": \"{{draftCampaignId}}\",\n  \"contractAddress\": \"0x1234567890abcdef1234567890abcdef12345678\",\n  \"blockNumber\": 18500000\n}"
						},
						"url": { "raw": "{{baseUrl}}/api/webhooks/ethereum", "host": ["{{baseUrl}}"], "path": ["api","webhooks","ethereum"] }
					}
				}
