PORT=3000
NODE_ENV=development

# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your_supabase_anon_key

# Blockchain
CHAIN_RPC_URL=http://localhost:8545
CHAIN_RPC_FALLBACK_URLS=http://localhost:8546,http://localhost:8547
CHAIN_RPC_MAX_RETRIES=2
CHAIN_RPC_RETRY_DELAY_MS=700
GAS_ALERT_THRESHOLD_ETH=0.01
GAS_LIMIT_BUFFER_PERCENT=15
PRIVATE_KEY=your_private_key_here
FUNDCHAIN_CONTRACT_ADDRESS=0xYourDeployedContractAddress

# Supabase direct Postgres connection for migration/seeder scripts
SUPABASE_DB_URL=postgresql://postgres:your_password@db.your-project-ref.supabase.co:5432/postgres

# Pinata (IPFS)
PINATA_API_KEY=
PINATA_SECRET_API_KEY=
PINATA_JWT=

# Casso (Bank Webhook)
PAYOS_CLIENT_ID=
PAYOS_API_KEY=
PAYOS_CHECKSUM_KEY=
